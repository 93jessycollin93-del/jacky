{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "purpose": "Scoped repository file access"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "purpose": "Issues, pull requests, commits, checks, and repository automation"
    },
    "browser": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "purpose": "UI inspection, accessibility snapshots, console, and network debugging"
    }
  }
}
